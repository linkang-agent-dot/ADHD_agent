import urllib.request, base64, ssl, json, urllib.parse
ctx = ssl.create_default_context()
ctx.check_hostname = False; ctx.verify_mode = ssl.CERT_NONE
auth = base64.b64encode(b'linkang:<TOKEN>').decode()
