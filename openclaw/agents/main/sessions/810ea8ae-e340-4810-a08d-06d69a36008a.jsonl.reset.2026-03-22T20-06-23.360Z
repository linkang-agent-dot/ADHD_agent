{"type":"message","id":"b1cc73ee","parentId":"f4db0b55","timestamp":"2026-03-22T08:51:03.541Z","message":{"role":"toolResult","toolCallId":"call_function_qumwevbr71dy_1","toolName":"exec","content":[{"type":"text","text":"xiaohongshu\n\n  /**\n   * 检查小红书登录状态\n   */\n  function check_login_status();\n\n  /**\n   * 删除 cookies 文件，重置登录状态。删除后需要重新登录。\n   */\n  function delete_cookies();\n\n  /**\n   * 收藏指定笔记或取消收藏（如已收藏将跳过收藏，如未收藏将跳过取消收藏）\n   *\n   * @param feed_id 小红书笔记ID，从Feed列表获取\n   * @param unfavorite? 是否取消收藏，true为取消收藏，false或未设置则为收藏\n   * @param xsec_token 访问令牌，从Feed列表的xsecToken字段获取\n   */\n  function favorite_feed(feed_id: string, unfavorite?: boolean, xsec_token: string);\n\n  /**\n   * 获取小红书笔记详情，返回笔记内容、图片、作者信息、互动数据（点赞/收藏/分享数）及评论列表。默认返回前10条一级评论，如需更多评论请设置load_all_comments=true\n   *\n   * @param click_more_replies? 【仅当load_all_comments为true时生效】是否展开二级回复。true展开子评论，false不展开（默认）\n   * @param feed_id 小红书笔记ID，从Feed列表获取\n   * @param limit? 【仅当load_all_comments为true时生效】限制加载的一级评论数量。例如20表示最多加载20条，默认20\n   * @param load_all_comments? 是否加载全部评论。false仅返回前10条一级评论（默认），true滚动加载更多评论\n   * @param reply_limit? 【仅当click_more_replies为true时生效】跳过回复数过多的评论。例如10表示跳过超过10条回复的，默认10\n   * @param scroll_speed? 【仅当load_all_comments为true时生效】滚动速度slow慢速、normal正常、fast快速\n   * @param xsec_token 访问令牌，从Feed列表的xsecToken字段获取\n   */\n  function get_feed_detail(click_more_replies?: boolean, feed_id: string, limit?: number, load_all_comments?: boolean, xsec_token: string);\n  // optional (2): reply_limit, scroll_speed\n\n  /**\n   * 获取登录二维码（返回 Base64 图片和超时时间）\n   */\n  function get_login_qrcode();\n\n  /**\n   * 为指定笔记点赞或取消点赞（如已点赞将跳过点赞，如未点赞将跳过取消点赞）\n   *\n   * @param feed_id 小红书笔记ID，从Feed列表获取\n   * @param unlike? 是否取消点赞，true为取消点赞，false或未设置则为点赞\n   * @param xsec_token 访问令牌，从Feed列表的xsecToken字段获取\n   */\n  function like_feed(feed_id: string, unlike?: boolean, xsec_token: string);\n\n  /**\n   * 获取首页 Feeds 列表\n   */\n  function list_feeds();\n\n  /**\n   * 发表评论到小红书笔记\n   *\n   * @param content 评论内容\n   * @param feed_id 小红书笔记ID，从Feed列表获取\n   * @param xsec_token 访问令牌，从Feed列表的xsecToken字段获取\n   */\n  function post_comment_to_feed(content: string, feed_id: string, xsec_token: string);\n\n  /**\n   * 发布小红书图文内容\n   *\n   * @param content 正文内容，不包含以#开头的标签内容，所有话题标签都用tags参数来生成和提供即可\n   * @param images 图片路径列表（至少需要1张图片）。支持两种方式：1. HTTP/HTTPS图片链接（自动下载）；2.\n   *               本地图片绝对路径（推荐，如:/Users/user/image.jpg）\n   * @param is_original? 是否声明原创（可选），true为声明原创，false或不填则不声明\n   * @param products? 商品关键词列表（可选），用于绑定带货商品。填写商品名称或商品ID，系统会自动搜索并选择第一个匹配结果。需账号已开通商品功能。示例: [面膜, 防晒霜SPF50]\n   * @param schedule_at? 定时发布时间（可选），ISO8601格式如 2024-01-20T10:30:00+08:00，支持1小时至14天内。不填则立即发布\n   * @param tags? 话题标签列表（可选参数），如 [美食, 旅行, 生活]\n   * @param title 内容标题（小红书限制：最多20个中文字或英文单词）\n   * @param visibility? 可见范围（可选），支持: 公开可见(默认)、仅自己可见、仅互关好友可见。不填则默认公开可见\n   */\n  function publish_content(content: string, images: string[], is_original?: boolean, products?: string[], title: string);\n  // optional (3): schedule_at, tags, visibility\n\n  /**\n   * 发布小红书视频内容（仅支持本地单个视频文件）\n   *\n   * @param content 正文内容，不包含以#开头的标签内容，所有话题标签都用tags参数来生成和提供即可\n   * @param products? 商品关键词列表（可选），用于绑定带货商品。填写商品名称或商品ID，系统会自动搜索并选择第一个匹配结果。需账号已开通商品功能。示例: [面膜, 防晒霜SPF50]\n   * @param schedule_at? 定时发布时间（可选），ISO8601格式如 2024-01-20T10:30:00+08:00，支持1小时至14天内。不填则立即发布\n   * @param tags? 话题标签列表（可选参数），如 [美食, 旅行, 生活]\n   * @param title 内容标题（小红书限制：最多20个中文字或英文单词）\n   * @param video 本地视频绝对路径（仅支持单个视频文件，如:/Users/user/video.mp4）\n   * @param visibility? 可见范围（可选），支持: 公开可见(默认)、仅自己可见、仅互关好友可见。不填则默认公开可见\n   */\n  function publish_with_video(content: string, products?: string[], schedule_at?: string, title: string, video: string);\n  // optional (2): tags, visibility\n\n  /**\n   * 回复小红书笔记下的指定评论\n   *\n   * @param comment_id? 目标评论ID，从评论列表获取\n   * @param content 回复内容\n   * @param feed_id 小红书笔记ID，从Feed列表获取\n   * @param user_id? 目标评论用户ID，从评论列表获取\n   * @param xsec_token 访问令牌，从Feed列表的xsecToken字段获取\n   */\n  function reply_comment_in_feed(comment_id?: string, content: string, feed_id: string, user_id?: string, xsec_token: string);\n\n  /**\n   * 搜索小红书内容（需要已登录）\n   *\n   * @param filters? 筛选选项\n   * @param keyword 搜索关键词\n   */\n  function search_feeds(filters?: unknown, keyword: string);\n\n  /**\n   * 获取指定的小红书用户主页，返回用户基本信息，关注、粉丝、获赞量及其笔记内容\n   *\n   * @param user_id 小红书用户ID，从Feed列表获取\n   * @param xsec_token 访问令牌，从Feed列表的xsecToken字段获取\n   */\n  function user_profile(user_id: string, xsec_token: string);\n\n  Examples:\n    mcporter call xiaohongshu.check_login_status()\n\n  Optional parameters hidden; run with --all-parameters to view all fields.\n\n  13 tools · 59ms · HTTP http://localhost:18060/mcp\n\nAssertion failed: !(handle->flags & UV_HANDLE_CLOSING), file src\\win\\async.c, line 76\n\n(Command exited with code 1)"}],"details":{"status":"completed","exitCode":1,"durationMs":900,"aggregated":"xiaohongshu\n\n  /**\n   * 检查小红书登录状态\n   */\n  function check_login_status();\n\n  /**\n   * 删除 cookies 文件，重置登录状态。删除后需要重新登录。\n   */\n  function delete_cookies();\n\n  /**\n   * 收藏指定笔记或取消收藏（如已收藏将跳过收藏，如未收藏将跳过取消收藏）\n   *\n   * @param feed_id 小红书笔记ID，从Feed列表获取\n   * @param unfavorite? 是否取消收藏，true为取消收藏，false或未设置则为收藏\n   * @param xsec_token 访问令牌，从Feed列表的xsecToken字段获取\n   */\n  function favorite_feed(feed_id: string, unfavorite?: boolean, xsec_token: string);\n\n  /**\n   * 获取小红书笔记详情，返回笔记内容、图片、作者信息、互动数据（点赞/收藏/分享数）及评论列表。默认返回前10条一级评论，如需更多评论请设置load_all_comments=true\n   *\n   * @param click_more_replies? 【仅当load_all_comments为true时生效】是否展开二级回复。true展开子评论，false不展开（默认）\n   * @param feed_id 小红书笔记ID，从Feed列表获取\n   * @param limit? 【仅当load_all_comments为true时生效】限制加载的一级评论数量。例如20表示最多加载20条，默认20\n   * @param load_all_comments? 是否加载全部评论。false仅返回前10条一级评论（默认），true滚动加载更多评论\n   * @param reply_limit? 【仅当click_more_replies为true时生效】跳过回复数过多的评论。例如10表示跳过超过10条回复的，默认10\n   * @param scroll_speed? 【仅当load_all_comments为true时生效】滚动速度slow慢速、normal正常、fast快速\n   * @param xsec_token 访问令牌，从Feed列表的xsecToken字段获取\n   */\n  function get_feed_detail(click_more_replies?: boolean, feed_id: string, limit?: nu