{"type":"message","id":"d121c74a","parentId":"1e641b5d","timestamp":"2026-03-22T09:05:52.389Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"mcporter 出问题了。让我直接用 python 脚本调用微博 API，然后输出结果给用户。"},{"type":"toolCall","id":"call_function_1llox24nynin_1","name":"write","arguments":{"path":"C:\\Users\\linkang\\.openclaw\\workspace\\weibo_tools.py","content":"\"\"\"\n微博热搜工具\n\"\"\"\nimport asyncio\nimport sys\nfrom mcp_server_weibo.weibo import WeiboCrawler\n\nasync def get_trendings(limit=5):\n    c = WeiboCrawler()\n    r = await c.get_trendings(limit)\n    return r\n\nasync def search_users(keyword, limit=5):\n    c = WeiboCrawler()\n    r = await c.search_users(keyword, limit)\n    return r\n\nasync def get_profile(uid):\n    c = WeiboCrawler()\n    r = await c.get_profile(uid)\n    return r\n\nif __name__ == \"__main__\":\n    import json\n    \n    if len(sys.argv) < 2:\n        print(\"用法: python weibo_tools.py <command> [args]\")\n        print(\"命令: trendings [数量], search <关键词> [数量], profile <uid>\")\n        sys.exit(1)\n    \n    cmd = sys.argv[1]\n    \n    if cmd == \"trendings\":\n        limit = int(sys.argv[2]) if len(sys.argv) > 2 else 5\n        r = asyncio.run(get_trendings(limit))\n        for i, item in enumerate(r, 1):\n            print(f\"{i}. {item.description} (热度: {item.trending})\")\n    elif cmd == \"search\":\n        keyword = sys.argv[2]\n        limit = int(sys.argv[3]) if len(sys.argv) > 3 else 5\n        r = asyncio.run(search_users(keyword, limit))\n        for u in r:\n            print(f\"- {u.get('screen_name', 'N/A')}: {u.get('description', '')}\")\n    elif cmd == \"profile\":\n        uid = int(sys.argv[2])\n        r = asyncio.run(get_profile(uid))\n        print(f\"昵称: {r.get('screen_name')}\")\n        print(f\"简介: {r.get('description')}\")\n        print(f\"粉丝: {r.get('followers_count')}\")\n        print(f\"关注: {r.get('follow_count')}\")\n    else:\n        print(f\"未知命令: {cmd}\")\n"}}],"api":"openai-completions","provider":"minimax","model":"MiniMax-M2.5","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774170331252}}
