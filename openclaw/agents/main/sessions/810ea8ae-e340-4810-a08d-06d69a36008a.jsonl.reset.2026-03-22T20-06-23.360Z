nt\n   * @param limit? Maximum number of results to return, defaults to 15\n   * @param page? Page number for pagination, defaults to 1\n   */\n  function search_content(keyword: string, limit?: number, page?: number): object;\n\n  /**\n   * Search for topics on Weibo based on a keyword.\n   * Returns:\n   * list[dict]: List of dictionaries containing search results\n   *\n   * @param keyword Search term to find content\n   * @param limit? Maximum number of results to return, defaults to 15\n   * @param page? Page number for pagination, defaults to 1\n   */\n  function search_topics(keyword: string, limit?: number, page?: number): object;\n\n  /**\n   * Get a Weibo user's followers.\n   * Returns:\n   * list[dict]: List of dictionaries containing follower information\n   *\n   * @param uid The unique identifier of the Weibo user\n   * @param limit? Maximum number of followers to return, defaults to 15\n   * @param page? Page number for pagination, defaults to 1\n   */\n  function get_followers(uid: number, limit?: number, page?: number): object;\n\n  /**\n   * Get a Weibo user's fans.\n   * Returns:\n   * list[dict]: List of dictionaries containing fan information\n   *\n   * @param uid The unique identifier of the Weibo user\n   * @param limit? Maximum number of fans to return, defaults to 15\n   * @param page? Page number for pagination, defaults to 1\n   */\n  function get_fans(uid: number, limit?: number, page?: number): object;\n\n  /**\n   * Get comments for a specific Weibo post.\n   * Returns:\n   * list[dict]: List of dictionaries containing comments\n   *\n   * @param feed_id The unique identifier of the Weibo post\n   * @param page? Page number for pagination, defaults to 1\n   */\n  function get_comments(feed_id: number, page?: number): object;\n\n  Examples:\n    mcporter call weibo.search_users(keyword: \"value\", limit: 5, page: 1)\n\n  10 tools · 67ms · HTTP http://localhost:4200/mcp\n\nAssertion failed: !(handle->flags & UV_HANDLE_CLOSING), file src