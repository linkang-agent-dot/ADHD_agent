{"type":"message","id":"0f10f545","parentId":"fa6062e1","timestamp":"2026-03-23T07:53:03.207Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，数据结构是 feeds -> noteCard -> displayTitle 和 interactInfo。让我修改脚本来正确提取数据。"},{"type":"toolCall","id":"call_function_0wg5hzd3ii2y_1","name":"write","arguments":{"path":"C:\\Users\\linkang\\.openclaw\\workspace\\test_mcp.py","content":"import requests, json, sys\nsys.stdout.reconfigure(encoding='utf-8')\ns = requests.Session()\nhdrs = {'Accept':'application/json, text/event-stream'}\nr1 = s.post('http://localhost:18060/mcp', json={'jsonrpc':'2.0','id':1,'method':'initialize','params':{'protocolVersion':'2024-11-05','capabilities':{},'clientInfo':{'name':'openclaw','version':'1.0'}}}, headers=hdrs)\nhdrs['Mcp-Session-Id'] = r1.headers['Mcp-Session-Id']\ns.post('http://localhost:18060/mcp', json={'jsonrpc':'2.0','method':'notifications/initialized'}, headers=hdrs)\n\n# 搜索，按热度排序\nresp = s.post('http://localhost:18060/mcp', json={'jsonrpc':'2.0','id':2,'method':'tools/call','params':{'name':'search_feeds','arguments':{'keyword':'旅游','filters':{'sort_by':'综合'}}}}, headers=hdrs)\ndata = resp.json()\nfeeds = json.loads(data['result']['text'])['feeds']\n\n# 提取笔记信息\nresults = []\nfor f in feeds:\n    if f.get('modelType') == 'note':\n        card = f.get('noteCard', {})\n        results.append({\n            'id': f.get('id'),\n            'xsec_token': f.get('xsecToken'),\n            'title': card.get('displayTitle', ''),\n            'type': card.get('type', ''),\n            'likes': card.get('interactInfo', {}).get('likedCount', '0'),\n            'collects': card.get('interactInfo', {}).get('collectedCount', '0'),\n            'comments': card.get('interactInfo', {}).get('commentCount', '0'),\n            'author': card.get('user', {}).get('nickname', '')\n        })\n\nprint(f\"共 {len(results)} 条笔记:\\n\")\nfor i, r in enumerate(results[:15]):\n    print(f\"{i+1}. {r['title'][:35]}\")\n    print(f\"   👍{r['likes']} | ⭐{r['collects']} | 💬{r['comments']} | @{r['author']}\")\n    print(f\"   ID:{r['id']}\")\n    print()\n"}}],"api":"openai-completions","provider":"minimax","model":"MiniMax-M2.5","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774252374534}}
