{"type":"message","id":"d2f013ab","parentId":"1780a88c","timestamp":"2026-03-23T09:00:50.664Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户想看小红书上有沒有关于 MiniMax 模型接入的教程或说明。"},{"type":"toolCall","id":"call_function_sfgik8ilkgfi_1","name":"write","arguments":{"path":"C:\\Users\\linkang\\.openclaw\\workspace\\search_minimax.py","content":"import requests, json, sys\nsys.stdout.reconfigure(encoding='utf-8')\ns = requests.Session()\nhdrs = {'Accept':'application/json, text/event-stream'}\nr1 = s.post('http://localhost:18060/mcp', json={'jsonrpc':'2.0','id':1,'method':'initialize','params':{'protocolVersion':'2024-11-05','capabilities':{},'clientInfo':{'name':'openclaw','version':'1.0'}}}, headers=hdrs)\nhdrs['Mcp-Session-Id'] = r1.headers['Mcp-Session-Id']\ns.post('http://localhost:18060/mcp', json={'jsonrpc':'2.0','method':'notifications/initialized'}, headers=hdrs)\n\n# 搜索 MiniMax 接入\nresp = s.post('http://localhost:18060/mcp', json={'jsonrpc':'2.0','id':2,'method':'tools/call','params':{'name':'search_feeds','arguments':{'keyword':'MiniMax 接入 API'}}}, headers=hdrs)\ndata = resp.json()\nfeeds = json.loads(data['result']['content'][0]['text'])['feeds']\n\nprint(\"找到关于 MiniMax 接入的笔记:\\n\")\nfor f in feeds[:15]:\n    if f.get('modelType') == 'note':\n        card = f.get('noteCard', {})\n        title = card.get('displayTitle', '无标题')\n        if title:\n            likes = card['interactInfo']['likedCount']\n            collects = card['interactInfo']['collectedCount']\n            author = card['user']['nickname']\n            print(f\"- {title[:50]}\")\n            print(f\"  👍{likes} | ⭐{collects} | @{author}\")\n            print()"}}],"api":"openai-completions","provider":"minimax","model":"MiniMax-M2.5","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774256435978}}
