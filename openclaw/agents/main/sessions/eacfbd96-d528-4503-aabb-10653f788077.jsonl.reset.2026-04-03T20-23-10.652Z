{"type":"message","id":"b52502a2","parentId":"e100ec5d","timestamp":"2026-04-03T07:12:51.755Z","message":{"role":"toolResult","toolCallId":"call_function_ec8w9z2ok0pa_1","toolName":"exec","content":[{"type":"text","text":"{'jsonrpc': '2.0', 'id': 2, 'result': {'content': [{'type': 'text', 'text': '✅ 已登录\\n用户名: xiaohongshu-mcp\\n\\n你可以使用其他功能了。'}]}}"}],"details":{"status":"completed","exitCode":0,"durationMs":5490,"aggregated":"{'jsonrpc': '2.0', 'id': 2, 'result': {'content': [{'type': 'text', 'text': '✅ 已登录\\n用户名: xiaohongshu-mcp\\n\\n你可以使用其他功能了。'}]}}","cwd":"C:\\Users\\linkang\\.openclaw\\workspace"},"isError":false,"timestamp":1775200371751}}
{"type":"message","id":"c5618d80","parentId":"b52502a2","timestamp":"2026-04-03T07:13:34.627Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The login check shows the MCP is working and logged in. But `list_feeds` returned 0 results. Let me try `list_feeds` directly to see what it returns."},{"type":"text","text":"MCP 已登录且正常。`list_feeds` 返回 0 是脚本逻辑问题，不是登录问题。先修复推送，再查原因：\n"},{"type":"toolCall","id":"call_function_iy12ch2bt9fb_1","name":"write","arguments":{"content":"import requests, json, sys, os, time\nfrom datetime import datetime\n\nsys.stdout.reconfigure(encoding='utf-8')\nsys.stderr.reconfigure(encoding='utf-8')\n\nMCP_URL = 'http://localhost:18060/mcp'\nUPLOAD_DIR = r'C:\\Users\\linkang\\.openclaw\\workspace\\uploads'\nos.makedirs(UPLOAD_DIR, exist_ok=True)\n\ndef init_mcp():\n    s = requests.Session()\n    hdrs = {'Accept': 'application/json, text/event-stream'}\n    r1 = s.post(MCP_URL, json={\n        'jsonrpc': '2.0', 'id': 1, 'method': 'initialize',\n        'params': {'protocolVersion': '2024-11-05', 'capabilities': {},\n                   'clientInfo': {'name': 'openclaw', 'version': '1.0'}}\n    }, headers=hdrs, timeout=10)\n    hdrs['Mcp-Session-Id'] = r1.headers.get('Mcp-Session-Id', '')\n    s.post(MCP_URL, json={'jsonrpc': '2.0', 'method': 'notifications/initialized'}, headers=hdrs)\n    return s, hdrs\n\ndef call_mcp(s, hdrs, tool_name, arguments):\n    resp = s.post(MCP_URL, json={\n        'jsonrpc': '2.0', 'id': 99, 'method': 'tools/call',\n        'params': {'name': tool_name, 'arguments': arguments}\n    }, headers=hdrs, timeout=30)\n    return json.loads(resp.json()['result']['content'][0]['text'])\n\ndef get_travel_feeds(s, hdrs):\n    # 先用 search_feeds 搜索旅游内容\n    kws = ['旅游', '旅行', '出游', '攻略', '打卡', '拍照', '度假', '景点', '风景', '春游', '踏青']\n    results = []\n    seen_ids = set()\n    \n    for kw in kws[:5]:  # 限制关键词数\n        try:\n            raw = call_mcp(s, hdrs, 'search_feeds', {'keyword': kw})\n            feeds = raw.get('feeds', []) or raw.get('items', [])\n            for f in feeds:\n                note_id = f.get('id', '')\n                if not note_id or note_id in seen_ids:\n                    continue\n                seen_ids.add(note_id)\n                \n                # 兼容不同格式\n                if f.get('type') == 'video':\n                    card = f.get('video', {})\n                    title = card.get('title', '') or card.get('desc', '')\n                    cover = card.get('cover', {})\n                    interact_count = card.get('interact_count', {})\n                else:\n                    card = f.get('noteCard', f)\n                    title = card.get('displayTitle', card.get('title', ''))\n                    cover = card.get('cover', {})\n                    interact_count = card.get('interactCount', card.get('interact_count', {}))\n                \n                like = interact_count.get('likedCount', 0) if isinstance(interact_count, dict) else 0\n                if not title:\n                    continue\n                results.append({\n                    'id': note_id,\n                    'title': title,\n                    'cover': cover,\n                    'like': like,\n                    'type': f.get('type', 'note')\n                })\n                if len(results) >= 8:\n                    break\n        except Exception as e:\n            print(f'搜索 {kw} 出错: {e}', file=sys.stderr)\n        \n        if len(results) >= 8:\n            break\n    \n    # 按点赞数排序取Top5\n    results.sort(key=lambda x: x['like'], reverse=True)\n    return results[:5]\n\ndef download_cover(url, path):\n    if not url:\n        return False\n    try:\n        r = requests.get(url, timeout=15)\n        if r.status_code == 200:\n            with open(path, 'wb') as f:\n                f.write(r.content)\n            return True\n    except:\n        pass\n    return False\n\ndef send_to_feishu(msgs):\n    from openclaw.tools.message import message as msg_tool\n    # 这个方式不行，直接用 requests 发飞书 webhook 更稳定\n    import urllib.request, urllib.parse\n    # 读飞书配置\n    try:\n        with open(r'C:\\Users\\linkang\\.openclaw\\workspace\\MCP_CONFIG.md', 'r', encoding='utf-8') as f:\n            config = f.read()\n        # 简单提取 webhook URL\n        import re\n        wh_match = re.search(r'feishu.*?webhook[^\\n]+(https://[^\\s\\n]+)', config, re.I)\n        if not wh_match:\n            wh_match = re.search(r'https://open[^\\s\"]+feishu[^\\s\"]+', config)\n    except:\n        wh_match = None\n    \n    # 直接用已知可用的飞书 webhook\n    webhook_url = 'https://open.feishu.cn/open-apis/bot/v2/hook/REDACTED'\n    \n    for msg in msgs:\n        try:\n            payload = json.dumps({'msg_type': 'text', 'content': {'text': msg}}).encode('utf-8')\n            req = urllib.request.Request(webhook_url, data=payload, headers={'Content-Type': 'application/json'})\n            urllib.request.urlopen(req, timeout=10)\n        except Exception as e:\n            print(f'发送失败: {e}', file=sys.stderr)\n\ndef main():\n    print('=== 小红书旅游推送开始 ===')\n    s, hdrs = init_mcp()\n    \n    # 验证登录\n    status = call_mcp(s, hdrs, 'check_login_status', {})\n    print(f'登录状态: {status}')\n    \n    feeds = get_travel_feeds(s, hdrs)\n    print(f'获取到 {len(feeds)} 条内容')\n    \n    today = datetime.now().strftime('%Y-%m-%d')\n    lines = [f'📊 小红书旅游热度Top5（{today}）', '']\n    msgs = []\n    \n    for i, f in enumerate(feeds, 1):\n        title = f['title']\n        like = f['like']\n        cover_url = f['cover'] if isinstance(f['cover'], str) else f['cover'].get('url', '')\n        \n        line = f'{i}. {title}\\n   👍 {like}'\n        lines.append(line)\n        msgs.append(line)\n        \n        # 下载封面图\n        if cover_url:\n            img_path = os.path.join(UPLOAD_DIR, f'push_{i}.jpg')\n            if download_cover(cover_url, img_path):\n                print(f'  下载封面: {img_path}')\n    \n    lines.append('')\n    lines.append('---每日11:30自动推送')\n    body = '\\n'.join(lines)\n    print(body)\n    \n    # 发飞书\n    send_to_feishu(msgs)\n    \n    # 保存数据\n    with open(os.path.join(UPLOAD_DIR, 'push_data.json'), 'w', encoding='utf-8') as fp:\n        json.dump({'feeds': feeds, 'body': body}, fp, ensure_ascii=False, indent=2)\n    \n    print(f'=== 完成 ===')\n\nif __name__ == '__main__':\n    main()\n","file_path":"C:\\Users\\linkang\\.openclaw\\workspace\\xiaohongshu_push_v3.py"}}],"api":"openai-completions","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775200371756}}
