{"type":"message","id":"7f038ab1","parentId":"2c9d7770","timestamp":"2026-03-26T03:05:18.882Z","message":{"role":"toolResult","toolCallId":"call_function_0dngflg04vbo_1","toolName":"read","content":[{"type":"text","text":"# 小红书旅游推送 v3 - 带封面图版（cron直接调用版）\nimport requests, json, sys, os, time\nfrom datetime import datetime\n\nsys.stdout.reconfigure(encoding='utf-8')\nMCP_URL = 'http://localhost:18060/mcp'\nUPLOAD_DIR = r'C:\\Users\\linkang\\.openclaw\\workspace\\uploads'\nos.makedirs(UPLOAD_DIR, exist_ok=True)\n\ndef init_mcp():\n    s = requests.Session()\n    hdrs = {'Accept': 'application/json, text/event-stream'}\n    r1 = s.post(MCP_URL, json={\n        'jsonrpc': '2.0', 'id': 1, 'method': 'initialize',\n        'params': {'protocolVersion': '2024-11-05', 'capabilities': {},\n                   'clientInfo': {'name': 'openclaw', 'version': '1.0'}}\n    }, headers=hdrs, timeout=10)\n    hdrs['Mcp-Session-Id'] = r1.headers.get('Mcp-Session-Id', '')\n    s.post(MCP_URL, json={'jsonrpc': '2.0', 'method': 'notifications/initialized'}, headers=hdrs)\n    return s, hdrs\n\ndef call_mcp(s, hdrs, tool_name, arguments):\n    resp = s.post(MCP_URL, json={\n        'jsonrpc': '2.0', 'id': 99, 'method': 'tools/call',\n        'params': {'name': tool_name, 'arguments': arguments}\n    }, headers=hdrs, timeout=30)\n    return json.loads(resp.json()['result']['content'][0]['text'])\n\ndef get_travel_feeds(s, hdrs):\n    raw = call_mcp(s, hdrs, 'list_feeds', {})\n    feeds = raw.get('feeds', [])\n    \n    travel_kws = ['旅游', '旅行', '出游', '攻略', '打卡', '拍照', '度假', '景点', '风景', '春游', '踏青']\n    results = []\n    seen_ids = set()\n    \n    for f in feeds:\n        if f.get('modelType') != 'note':\n            continue\n        note_id = f.get('id', '')\n        if note_id in seen_ids:\n            continue\n        seen_ids.add(note_id)\n        \n        card = f.get('noteCard', {})\n        title = card.get('displayTitle', '')\n        if not any(kw in title for kw in travel_kws):\n            continue\n        \n        cover = card.get('cover', {})\n        img_url = cover.get('urlDefault', '') or cover.get('urlPre', '')\n        interact = card.get('interactInfo', {})\n        \n        results.append({\n            'title': title[:35],\n            'likes': interact.get('likedCount', '0'),\n            'collects': interact.get('collectedCount', '0'),\n            'author': card.get('user', {}).get('nickname', ''),\n            'note_id': note_id,\n            'token': f.get('xsecToken', ''),\n            'img_url': img_url,\n            'type': card.get('type', 'normal'),\n        })\n        \n        if len(results) >= 5:\n            break\n    \n    # 如果旅游内容不够5条，补充其他内容\n    if len(results) < 5:\n        for f in feeds:\n            if len(results) >= 5:\n                break\n            note_id = f.get('id', '')\n            if note_id in seen_ids:\n                continue\n            seen_ids.add(note_id)\n            \n            card = f.get('noteCard', {})\n            cover = card.get('cover', {})\n            img_url = cover.get('urlDefault', '') or cover.get('urlPre', '')\n            interact = card.get('interactInfo', {})\n            results.append({\n                'title': card.get('displayTitle', '')[:35],\n                'likes': interact.get('likedCount', '0'),\n                'collects': interact.get('collectedCount', '0'),\n                'author': card.get('user', {}).get('nickname', ''),\n                'note_id': note_id,\n                'token': f.get('xsecToken', ''),\n                'img_url': img_url,\n                'type': card.get('type', 'normal'),\n            })\n    \n    return results\n\ndef get_note_detail(s, hdrs, note_id, token):\n    try:\n        time.sleep(0.5)\n        raw = call_mcp(s, hdrs, 'get_feed_detail', {\n            'feed_id': note_id,\n            'xsec_token': token,\n            'load_all_comments': False,\n            'limit': 1\n        })\n        note_data = raw.get('data', {}).get('note', {})\n        desc = note_data.get('desc', '')[:80]\n        images = note_data.get('imageList', [])\n        detail_img = images[0].get('urlDefault', '') if images else ''\n        return desc, detail_img\n    except Exception as e:\n        return \"\", \"\"\n\ndef download_img(s, url, path):\n    try:\n        if not url:\n            return False\n        r = s.get(url, timeout=15)\n        if r.status_code == 200:\n            with open(path, 'wb') as f:\n                f.write(r.content)\n            return True\n    except:\n        pass\n    return False\n\ndef format_count(c):\n    try:\n        n = int(c)\n        if n >= 10000:\n            return f\"{n//10000}万\"\n        return str(n)\n    except:\n        return c\n\nif __name__ == \"__main__\":\n    print(\"=== 小红书旅游推送开始 ===\")\n    s, hdrs = init_mcp()\n    \n    # 1. 获取Feeds\n    results = get_travel_feeds(s, hdrs)\n    print(f\"获取Feeds: {len(results)}条\")\n    \n    # 2. 获取详情和封面图\n    for i, r in enumerate(results):\n        summary, detail_img = get_note_detail(s, hdrs, r['note_id'], r['token'])\n        r['summary'] = summary\n        if detail_img:\n            r['img_url'] = detail_img\n        print(f\"  [{i+1}] {r['title'][:20]} | 👍{r['likes']} | 图:{bool(r['img_url'])}\")\n    \n    # 3. 下载封面图\n    img_map = {}\n    for i, r in enumerate(results):\n        if r.get('img_url'):\n            path = os.path.join(UPLOAD_DIR, f\"push_{i+1}.jpg\")\n            ok = download_img(s, r['img_url'], path)\n            if ok:\n                img_map[i+1] = path\n                print(f\"  图片{i+1}下载: OK -> {path}\")\n    \n    # 4. 构建消息（带图片）\n    date = datetime.now().strftime(\"%Y-%m-%d\")\n    \n    # 先发文字\n    text_lines = [f\"📊 小红书旅游热度Top5（{date}）\\n\"]\n    for i, r in enumerate(results, 1):\n        emoji = \"🎬\" if r['type'] == 'video' else \"📝\"\n        text_lines.append(f\"{emoji} {i}. {r['title']}\")\n        text_lines.append(f\"   👍{format_count(r['likes'])} | ⭐{format_count(r['collects'])} | @{r['author']}\")\n        if r.get('summary'):\n            text_lines.append(f\"   📝 {r['summary']}\")\n        text_lines.append(\"\")\n    text_lines.append(\"---每日11:30自动推送\")\n    \n    msg_text = '\\n'.join(text_lines)\n    print(\"\\n消息内容:\")\n    print(msg_text)\n    \n    # 保存结果供飞书推送使用\n    output = {\n        'msg': msg_text,\n        'images': img_map,  # {index: path}\n        'results': results\n    }\n    output_path = os.path.join(UPLOAD_DIR, 'push_data.json')\n    with open(output_path, 'w', encoding='utf-8') as f:\n        json.dump(output, f, ensure_ascii=False, indent=2)\n    print(f\"\\n数据已保存: {output_path}\")\n    print(f\"共 {len(img_map)} 张图片\")\n    print(\"=== 完成 ===\")\n"}],"isError":false,"timestamp":1774494318881}}
