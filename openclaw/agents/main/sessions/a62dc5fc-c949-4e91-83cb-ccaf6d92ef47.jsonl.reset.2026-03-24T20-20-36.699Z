{"type":"message","id":"112f5e49","parentId":"615cfc9d","timestamp":"2026-03-24T14:16:58.913Z","message":{"role":"toolResult","toolCallId":"call_function_w2egu7ovj6hf_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python\n# -*- coding: utf-8 -*-\n\"\"\"\n携程国际机票价格追踪器\n成都出发 -> 10条热门航线\n利用携程日历条获取每天最低价（无需通过验证码）\n\"\"\"\n\nimport sys\nsys.stdout.reconfigure(encoding='utf-8')\n\nimport json\nimport os\nimport re\nimport time\nimport argparse\nfrom datetime import datetime, timedelta\nfrom playwright.sync_api import sync_playwright\n\nWORKSPACE = r\"C:\\ADHD_agent\\openclaw\\workspace\"\nHISTORY_FILE = os.path.join(WORKSPACE, \"flight_data\", \"flight_history.json\")\nUPLOADS_DIR = os.path.join(WORKSPACE, \"uploads\")\nTREND_CHART = os.path.join(UPLOADS_DIR, \"flight_trend.png\")\n\nROUTES = [\n    {\"name\": \"东京\",     \"code\": \"tyo\", \"country\": \"日本\"},\n    {\"name\": \"大阪\",     \"code\": \"osa\", \"country\": \"日本\"},\n    {\"name\": \"曼谷\",     \"code\": \"bkk\", \"country\": \"泰国\"},\n    {\"name\": \"新加坡\",   \"code\": \"sin\", \"country\": \"新加坡\"},\n    {\"name\": \"首尔\",     \"code\": \"sel\", \"country\": \"韩国\"},\n    {\"name\": \"香港\",     \"code\": \"hkg\", \"country\": \"中国香港\"},\n    {\"name\": \"台北\",     \"code\": \"tpe\", \"country\": \"中国台湾\"},\n    {\"name\": \"胡志明市\", \"code\": \"sgn\", \"country\": \"越南\"},\n    {\"name\": \"吉隆坡\",   \"code\": \"kul\", \"country\": \"马来西亚\"},\n    {\"name\": \"巴厘岛\",   \"code\": \"dps\", \"country\": \"印尼\"},\n]\n\nORIGIN = \"ctu\"\nHISTORY_DAYS = 30\nPRICE_MIN = 400\nPRICE_MAX = 30000\nCALENDAR_SPAN = 7  # days visible in calendar bar per page load\n\n\ndef load_history() -> dict:\n    if os.path.exists(HISTORY_FILE):\n        with open(HISTORY_FILE, \"r\", encoding=\"utf-8\") as f:\n            return json.load(f)\n    return {}\n\n\ndef save_history(history: dict):\n    cutoff = (datetime.now() - timedelta(days=HISTORY_DAYS)).strftime(\"%Y-%m-%d\")\n    for k in [k for k in history if k < cutoff]:\n        del history[k]\n    os.makedirs(os.path.dirname(HISTORY_FILE), exist_ok=True)\n    with open(HISTORY_FILE, \"w\", encoding=\"utf-8\") as f:\n        json.dump(history, f, ensure_ascii=False, indent=2)\n\n\ndef parse_calendar_prices(visible_text: str, year: int, target_start: str, target_end: str):\n    \"\"\"\n    Parse date-price pairs from the calendar bar visible text.\n    Calendar shows lines like: \"04-22周三\\n¥1150低\\n\\t\\n04-23周四\\n¥1342\"\n    Returns list of {date: YYYY-MM-DD, price: int} within the target range.\n    \"\"\"\n    pattern = r'(\\d{2})-(\\d{2})[\\u5468][一二三四五六日]\\s*\\n\\s*[¥\\uffe5](\\d+)'\n    results = []\n\n    for m in re.finditer(pattern, visible_text):\n        month, day, price = int(m.group(1)), int(m.group(2)), int(m.group(3))\n        if PRICE_MIN <= price <= PRICE_MAX:\n            date_str = f\"{year}-{month:02d}-{day:02d}\"\n            if target_start <= date_str <= target_end:\n                results.append({\"date\": date_str, \"price\": price})\n\n    # Also try .price selector data (format: \"¥1212\")\n    price_only = re.findall(r'[¥\\uffe5](\\d{3,5})', visible_text)\n    for p_str in price_only:\n        p = int(p_str)\n\n[338 more lines in file. Use offset=81 to continue.]"}],"isError":false,"timestamp":1774361818910}}
{"type":"message","id":"479cab22","parentId":"112f5e49","timestamp":"2026-03-24T14:17:02.221Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The script doesn't have a \"direct flight only\" filter. It just gets prices from the calendar. Let me check if there's a way to filter by direct flights in the URL or parameters. Let me look at the URL construction part."},{"type":"toolCall","id":"call_function_1mil71dz1bxa_1","name":"read","arguments":{"path":"C:\\ADHD_agent\\openclaw\\workspace\\ctrip_tracker.py","offset":81,"limit":100}}],"api":"openai-completions","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774361818914}}
{"type":"message","id":"62103108","parentId":"479cab22","timestamp":"2026-03-24T14:17:02.231Z","message":{"role":"toolResult","toolCallId":"call_function_1mil71dz1bxa_1","toolName":"read","content":[{"type":"text","text":"        if PRICE_MIN <= p <= PRICE_MAX:\n            already = any(r[\"price\"] == p for r in results)\n            if not already:\n                pass  # skip standalone prices without date context\n\n    seen = set()\n    deduped = []\n    for r in results:\n        key = (r[\"date\"], r[\"price\"])\n        if key not in seen:\n            seen.add(key)\n            deduped.append(r)\n    return deduped\n\n\ndef fetch_calendar_prices(page, route_code: str, route_name: str, anchor_date: str,\n                          target_start: str, target_end: str, year: int) -> list:\n    \"\"\"Load one page and extract calendar bar prices.\"\"\"\n    url = f\"https://flights.ctrip.com/online/list/oneway-{ORIGIN}-{route_code}?depdate={anchor_date}\"\n    try:\n        page.goto(url, timeout=15000)\n        page.wait_for_selector('.price', timeout=10000)\n        time.sleep(1)\n        visible = page.inner_text('body')\n        return parse_calendar_prices(visible, year, target_start, target_end)\n    except Exception as e:\n        print(f\"  ✗ {route_name} (anchor={anchor_date}): {e}\")\n        return []\n\n\ndef scan_route_in_range(page, route: dict, days_start: int, days_end: int,\n                        test_mode: bool = False) -> dict | None:\n    \"\"\"\n    Scan one route across a date range using calendar bar.\n    Opens pages every ~7 days to cover the full range.\n    \"\"\"\n    today = datetime.now()\n    start_date = today + timedelta(days=days_start)\n    end_date = today + timedelta(days=days_end)\n    target_start = start_date.strftime(\"%Y-%m-%d\")\n    target_end = end_date.strftime(\"%Y-%m-%d\")\n    year = start_date.year\n\n    all_prices = []\n\n    if test_mode:\n        anchors = [start_date + timedelta(days=3)]\n    else:\n        anchors = []\n        current = start_date + timedelta(days=3)\n        while current <= end_date:\n            anchors.append(current)\n            current += timedelta(days=CALENDAR_SPAN)\n\n    consecutive_fail = 0\n    for anchor in anchors:\n        if consecutive_fail >= 3:\n            print(f\"  ⚠️ {route['name']}: 连续失败，跳过\")\n            break\n\n        anchor_str = anchor.strftime(\"%Y-%m-%d\")\n        prices = fetch_calendar_prices(\n            page, route[\"code\"], route[\"name\"], anchor_str,\n            target_start, target_end, year\n        )\n        if prices:\n            all_prices.extend(prices)\n            consecutive_fail = 0\n            best = min(prices, key=lambda x: x[\"price\"])\n            print(f\"  ✓ {route['name']} ({anchor_str}): 获取{len(prices)}个价格，最低¥{best['price']}({best['date']})\")\n        else:\n            consecutive_fail += 1\n            print(f\"  ✗ {route['name']} ({anchor_str}): 未获取到价格\")\n\n        time.sleep(2)\n\n    if all_prices:\n        cheapest = min(all_prices, key=lambda x: x[\"price\"])\n        return {\"price\": cheapest[\"price\"], \"dep_date\": cheapest[\"date\"]}\n    return None\n\n\ndef scan_all_routes(routes: list, windows: list, test_mode: bool = False) -> dict:\n    \"\"\"Launch one browser and scan all routes across all windows.\"\"\"\n    today_data = {}\n    route_fail_count = 0\n\n    with sync_playwright() as p:\n        browser = p.chromium.launch(headless=True)\n        context = browser.new_context(\n            user_agent=\"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36\"\n        )\n        page = context.new_page()\n\n        for label, days_start, days_end, suffix, window_key in windows:\n            today_d = datetime.now()\n            start_d = (today_d + timedelta(days=days_start)).strftime(\"%m.%d\")\n            end_d = (today_d + timedelta(days=days_end)).strftime(\"%m.%d\")\n            print(f\"\\n📅 {label} ({start_d} ~ {end_d})\")\n\n\n[238 more lines in file. Use offset=181 to continue.]"}],"isError":false,"timestamp":1774361822227}}
{"type":"message","id":"b7e157e6","parentId":"62103108","timestamp":"2026-03-24T14:17:19.316Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The script doesn't have a \"direct flight only\" option. The calendar view shows all flights (with or without stops). I'd need to add a filter parameter to the URL or use a different approach.\n\nLooking at the URL structure: `https://flights.ctrip.com/online/list/oneway-{ORIGIN}-{route_code}?depdate={anchor_date}`\n\nFor direct flights only, I might be able to add a parameter like `&stop=0` or similar. Let me check if there's a way to filter directly.\n\nActually, the script uses the calendar bar view which might not support filtering easily. Let me try a different approach - I'll open the browser and see if I can figure out the direct flight filter parameter."},{"type":"text","text":"脚本目前没有直飞筛选功能，我直接帮你看携程日历上有没有直飞标签。\n"},{"type":"toolCall","id":"call_function_2dztfo1kzlp0_1","name":"exec","arguments":{"command":"python - <<'EOF'\nfrom playwright.sync_api import sync_playwright\nimport time\n\nwith sync_playwright() as p:\n    browser = p.chromium.launch(headless=True)\n    page = browser.new_page()\n    \n    # 成都-东京，6月下旬\n    url = \"https://flights.ctrip.com/online/list/oneway-ctu-tyo?depdate=2026-06-24\"\n    page.goto(url, timeout=15000)\n    page.wait_for_selector('.price', timeout=10000)\n    time.sleep(2)\n    \n    # 看页面结构，有没有\"直飞\"相关标签\n    text = page.inner_text('body')\n    \n    # 找价格和航班信息\n    import re\n    # 找所有价格\n    prices = re.findall(r'[¥\\uffe5](\\d+)', text)\n    print(f\"找到价格: {prices[:10]}\")\n    \n    # 找直飞相关文本\n    direct = re.findall(r'直飞[^\\n]{0,30}', text)\n    print(f\"直飞标签: {direct[:5]}\")\n    \n    # 截图看看\n    page.screenshot(path=r\"C:\\ADHD_agent\\openclaw\\workspace\\uploads\\flight_direct.png\", full_page=False)\n    print(\"截图已保存\")\n    \n    # 关闭\n    browser.close()\nEOF","yieldMs":30000,"timeout":45}}],"api":"openai-completions","provider":"minimax","model":"